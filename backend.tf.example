# Remote state backend — copy to backend.tf and fill in your values.
# Use a separate state key per environment.

terraform {
  backend "s3" {
    bucket         = "your-terraform-state-bucket"
    key            = "rds/terraform.tfstate"   # change per env: rds-prod, rds-staging
    region         = "us-east-1"
    encrypt        = true
    dynamodb_table = "terraform-state-lock"
  }
}
